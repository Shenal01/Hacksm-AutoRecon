# ==============================================================================
# Pentest Automation Environment Variables
#
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual production API keys below.
# 3. DO NOT COMMIT .env TO GITHUB.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Reconnaissance API Keys
# ------------------------------------------------------------------------------
# Shodan API Key (Required for Phase 1 enrichment and passive vulnerability scanning)
SHODAN_API_KEY=your_shodan_api_key_here

# GitHub Personal Access Token (Required for Phase 1 leak hunting and dorking)
GITHUB_TOKEN=your_github_pat_here

# ------------------------------------------------------------------------------
# 2. Alerting & Webhooks
# ------------------------------------------------------------------------------
# Discord Webhook URL (Required for Phase 6/7 reporting of critical vulnerabilities)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# ------------------------------------------------------------------------------
# 3. AI Engines
# ------------------------------------------------------------------------------
# Gemini API Key (Required for Phase 6 critical vulnerability false-positive verification)
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------------------------
# 4. n8n Authentication (Optional)
# ------------------------------------------------------------------------------
# Set basic auth credentials to protect your n8n instance from the public internet
# If left blank, you will configure an owner account upon first boot
# N8N_BASIC_AUTH_ACTIVE=true
# N8N_BASIC_AUTH_USER=admin
# N8N_BASIC_AUTH_PASSWORD=super_secure_password
