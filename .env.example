# ==============================================================================
# Pentest Automation Environment Variables
#
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual production API keys below.
# 3. DO NOT COMMIT .env TO GITHUB.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Reconnaissance API Keys
# ------------------------------------------------------------------------------
# Shodan API Key (Required for Phase 1 enrichment and passive vulnerability scanning)
SHODAN_API_KEY=your_shodan_api_key_here

# GitHub Personal Access Token (Required for Phase 1 leak hunting and dorking)
GITHUB_TOKEN=your_github_pat_here

# Optional alias for tools/bootstrap paths that also support GH_TOKEN
GH_TOKEN=

# ------------------------------------------------------------------------------
# 2. Scanning Tool API Keys
# ------------------------------------------------------------------------------
# WPScan API Token (Required for WordPress CVE lookups — free at https://wpscan.com/api)
WPSCAN_API_TOKEN=your_wpscan_api_token_here

# SSH password used by the n8n container to execute commands in pentest-tools-api
TOOLS_SSH_PASSWORD=replace_with_a_long_random_password

# Shared token required in x-scan-token header for /webhook/start-scan
SCAN_API_TOKEN=replace_with_a_random_64_char_secret

# Subfinder Provider Keys (Optional — improves subdomain coverage significantly)
# Configure these inside the container at: ~/.config/subfinder/provider-config.yaml
# See: https://docs.projectdiscovery.io/tools/subfinder/install#post-install-configuration
# Set the values directly there — they are NOT passed via .env

# ------------------------------------------------------------------------------
# 3. Alerting & Webhooks
# ------------------------------------------------------------------------------
# Discord Webhook URL (Required for Phase 6/7 vulnerability alerts and scan completion)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# ------------------------------------------------------------------------------
# 4. AI Engines
# ------------------------------------------------------------------------------
# Gemini API Key (Required for Phase 6 critical vulnerability verification and reports)
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------------------------
# 5. Out-of-Band (OAST) Detection Server
# ------------------------------------------------------------------------------
# Required for blind XSS, blind SSRF, and out-of-band injection detection.
# Get a free server at: https://app.interactsh.com/ or run your own:
# docker run -p 1337:1337 projectdiscovery/interactsh-server
OAST_SERVER=your-oast-server.oast.fun

# ------------------------------------------------------------------------------
# 6. Automated Monitoring
# ------------------------------------------------------------------------------
# Comma-separated root domains to monitor weekly for new subdomains.
# Leave blank to disable scheduled monitoring by default.
MONITOR_TARGETS=

# ------------------------------------------------------------------------------
# 7. n8n Web Interface Authentication (REQUIRED — secures the n8n dashboard)
# ------------------------------------------------------------------------------
# Without these, anyone with network access can view/modify your workflows.
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_to_a_strong_password


